# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram user IDs allowed to use this bot
# Find your ID: message @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# Timezone for day-bucketing (used for streaks, summaries, reminders)
TZ=Asia/Kolkata

# Hour (0-23) in local time to send daily habit reminder
REMINDER_HOUR=20

# SQLite database file path
DB_PATH=ledger.db
